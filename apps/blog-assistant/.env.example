# =============================================================================
# blog-assistant 环境变量说明
# 复制为 .env.local 后填写，或运行: pnpm blog-assistant:setup-env
#
# 零配置预览：不建 .env.local 也可 pnpm blog-assistant:dev（自动演示模式）
# 本地生产效果：填好「必填」4 项 + BLOG_ASSISTANT_DEMO=0
# =============================================================================

# -----------------------------------------------------------------------------
# Upstash Vector（与 kb-search、tools/rag 共用同一索引）
# 控制台: https://console.upstash.com/ → Vector → 你的 Index → REST API
# Index 维度须为 1024（BAAI/bge-m3）
# -----------------------------------------------------------------------------

# Upstash Vector REST 接口地址
UPSTASH_VECTOR_REST_URL=

# Upstash Vector REST 鉴权 Token
UPSTASH_VECTOR_REST_TOKEN=

# -----------------------------------------------------------------------------
# DeepSeek 对话模型（Agent ReAct + RAG 生成回答）
# 控制台: https://platform.deepseek.com → API Keys
# -----------------------------------------------------------------------------

# DeepSeek API Key（也可改用 OPENAI_API_KEY + OPENAI_BASE_URL）
DEEPSEEK_API_KEY=

# DeepSeek OpenAI 兼容接口根地址
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 对话模型名，默认 deepseek-chat
DEEPSEEK_CHAT_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# Embedding 向量化（检索 query 转向量；须与索引脚本相同模型/维度）
# 控制台: https://cloud.siliconflow.cn → API 密钥
# 注意：不能用 DeepSeek Key 做 Embedding
# -----------------------------------------------------------------------------

# 硅基流动 API Key（或改用 EMBEDDING_API_KEY）
SILICONFLOW_API_KEY=

# Embedding 服务 OpenAI 兼容地址
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# Embedding 模型，默认 BAAI/bge-m3（1024 维）
EMBEDDING_MODEL=BAAI/bge-m3

# -----------------------------------------------------------------------------
# 前端与引用链接
# -----------------------------------------------------------------------------

# 博客站点根 URL，用于引用卡片跳转（会暴露到浏览器，勿放密钥）
NEXT_PUBLIC_BLOG_BASE_URL=https://blog.zkkysqs.top

# -----------------------------------------------------------------------------
# 演示模式 / 生产行为
# -----------------------------------------------------------------------------

# 演示模式开关：1=强制模拟流  0=强制真实 AI  不填=开发时无 Key 自动演示
# BLOG_ASSISTANT_DEMO=0

# -----------------------------------------------------------------------------
# 访问门控与限流（不填 = 无密码、不限流）
# -----------------------------------------------------------------------------

# 访问密码；设后 API 需在请求头 x-blog-assistant-password 携带
BLOG_ASSISTANT_PASSWORD=

# 与 kb-search 共用的密码别名（填任一项即可）
KB_SEARCH_PASSWORD=

# 设密码时，无密码访客的每日对话次数；0=完全拒绝访客
BLOG_ASSISTANT_DAILY_LIMIT=20

# -----------------------------------------------------------------------------
# Neon Postgres（配置 DATABASE_URL 后，可在页面「高级」主动开启持久化）
# 默认关闭：MemorySaver + 浏览器 localStorage；开启后写入 Neon checkpoint
# -----------------------------------------------------------------------------

# Postgres 连接串，例: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# 连接池最大连接数，默认 10
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# Upstash Redis（多实例/Vercel 部署时的准确 IP 限流；不填用进程内计数）
# -----------------------------------------------------------------------------

# Upstash Redis REST URL
# UPSTASH_REDIS_REST_URL=

# Upstash Redis REST Token
# UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# LangSmith 可观测（Trace Agent / Tool 调用链）
# 控制台: https://smith.langchain.com/
# -----------------------------------------------------------------------------

# 是否开启 Trace：true / false
# LANGCHAIN_TRACING_V2=true

# LangSmith API Key
# LANGCHAIN_API_KEY=

# LangSmith 项目名，便于在控制台筛选
# LANGCHAIN_PROJECT=blog-assistant

# -----------------------------------------------------------------------------
# Eval 回归脚本（pnpm blog-assistant:eval）
# -----------------------------------------------------------------------------

# 被测服务地址，默认 http://localhost:3010
# EVAL_BASE_URL=http://localhost:3010

# golden 通过率阈值，0～1，默认 0.8
# EVAL_PASS_THRESHOLD=0.8

# -----------------------------------------------------------------------------
# Agent 图安全与路由
# -----------------------------------------------------------------------------

# ReAct 最大往返步数（agent ↔ tools），防无限循环，默认 15
# AGENT_RECURSION_LIMIT=15

# 意图路由：rules=仅规则  auto=歧义时 LLM（默认）  llm=始终 LLM 分类
# AGENT_LLM_ROUTER=auto

# -----------------------------------------------------------------------------
# RAG 检索增强
# -----------------------------------------------------------------------------

# 检索重排序：1=开启（向量+关键词混合）  0=关闭
# RAG_RERANK=1

# 重排序时向量分权重，默认 0.65（另 0.35 为关键词重叠）
# RAG_RERANK_VECTOR_WEIGHT=0.65

# 重排序时关键词分权重，默认 0.35
# RAG_RERANK_KEYWORD_WEIGHT=0.35

# HyDE 假设文档检索：off=关  auto=复杂/多轮时开（默认）  on=始终开
# RAG_HYDE=auto
