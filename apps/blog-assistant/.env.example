# =============================================================================
# 本地只看 UI：不用填任何变量，直接 pnpm blog-assistant:dev
# 开发模式下缺少 DEEPSEEK_API_KEY 会自动进入「演示模式」（模拟对话流）
# 强制演示：BLOG_ASSISTANT_DEMO=1  关闭演示：BLOG_ASSISTANT_DEMO=0
# =============================================================================

# 与 kb-search / tools/rag 共用 Upstash Vector 索引
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# DeepSeek 对话（Agent / RAG）— 本地 UI 预览可不填
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Embedding 查询（须与索引时相同模型 / 维度）
SILICONFLOW_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

NEXT_PUBLIC_BLOG_BASE_URL=https://blog.zkkysqs.top

# 访问门控（不填 = 无密码、无限流）
BLOG_ASSISTANT_PASSWORD=
KB_SEARCH_PASSWORD=
BLOG_ASSISTANT_DAILY_LIMIT=20

# 阶段 3：Neon Postgres（checkpoint + 会话表）— 本地可不填
DATABASE_URL=
DATABASE_POOL_MAX=10

# 可选：Upstash Redis 多实例限流
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# 可选：LangSmith Trace
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=blog-assistant

# Eval 脚本（pnpm eval）
# EVAL_BASE_URL=http://localhost:3010
# EVAL_PASS_THRESHOLD=0.8
