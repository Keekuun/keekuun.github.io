# Upstash Vector（控制台 → Index → REST API，维度见下方 EMBEDDING）
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# DeepSeek 仅 kb-search 对话用，索引脚本不要填到 SILICONFLOW 里
# DEEPSEEK_API_KEY=

# Embedding：DeepSeek 暂无官方向量 API，默认硅基流动 BGE-M3（1024 维）
# 在 https://cloud.siliconflow.cn 申请 Key
SILICONFLOW_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
# 单条 Embedding（推荐）：bge-m3 单条最多约 8192 tokens
EMBEDDING_CONCURRENCY=6
EMBEDDING_MAX_CHARS=6000
RAG_CHUNK_MAX_CHARS=1200

# 也可用其它 OpenAI 兼容 Embedding（须与 Upstash Index 维度一致）
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# 勿设置 OPENAI_BASE_URL=https://api.deepseek.com，否则 Embedding 会 401

BLOG_BASE_URL=https://blog.zkkysqs.top

# 仅手动 full_reindex 时清空索引（会额外消耗写入配额）
# RAG_FORCE_RESET=1

# 断点续传 upsert（保留 .upsert-payload.json）
# RAG_RESUME_UPSERT_FROM=4800

# 本地增量：RAG_GIT_BEFORE=HEAD~1 RAG_GIT_AFTER=HEAD pnpm index:incremental
