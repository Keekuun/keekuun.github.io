//将会被自动应用的全局样式文件，会生成在最终的 CSS 文件结尾，具有比默认样式更高的优先级。
summary + pre {
  color: cyan;
}

::selection {
  background: lightseagreen;
  color: cornsilk;
}

.content__default code {
  font-size: 1rem !important;
}

.content__default pre code {
  font-size: 0.85rem !important;
}

.content__default pre[class*="language"] {
  padding-top: 2.5rem !important;
}

.content__default pre[class*="language"]::before {
  position: absolute;
  top: 1rem;
  left: 3.5rem;
  content: "";
  width: 11px;
  height: 11px;
  border-radius: 50%;
  /* 	第一个小圆点 */
  background-color: #ff5f56;
  /* 	后面两个小圆点 */
  -webkit-box-shadow: 18px 0 0 0 #ffbd2e, 36px 0 0 0 #27c93f;
  box-shadow: 18px 0 0 0 #ffbd2e, 36px 0 0 0 #27c93f;
}

.abstract-item .reco-account:before {
  color: #ff5f56 !important;
}

.abstract-item .reco-date:before {
  color: #ffbd2e !important;
}

.abstract-item .reco-tag:before {
  color: #27c93f !important;
}

div[class*="language-"].line-numbers-mode .line-numbers-wrapper {
  top: 1.25rem !important;
}

.code-copy{
    position: absolute;
    top: 20px;
    right: 30px;
}

.content__default .mermaid {
  text-align: center;
  margin: 1.5rem 0;
  overflow-x: auto;
}

.content__default .mermaid svg {
  max-width: 100%;
  height: auto;
}

.content__default .mermaid.mermaid-zoomable {
  cursor: zoom-in;
  position: relative;
  padding: 0.5rem;
  border-radius: 8px;
  transition: background-color 0.2s ease, box-shadow 0.2s ease;
}

.content__default .mermaid.mermaid-zoomable:hover {
  background-color: rgba(66, 185, 131, 0.08);
  box-shadow: 0 0 0 1px rgba(66, 185, 131, 0.25);
}

.content__default .mermaid.mermaid-zoomable:focus {
  outline: 2px solid #42b983;
  outline-offset: 2px;
}

body.mermaid-zoom-open {
  overflow: hidden;
}

.mermaid-zoom-overlay {
  position: fixed;
  inset: 0;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mermaid-zoom-overlay[hidden] {
  display: none !important;
}

.mermaid-zoom-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  cursor: zoom-out;
}

.mermaid-zoom-panel {
  position: relative;
  z-index: 1;
  width: unquote('min(96vw, 1400px)')
  max-height: 92vh;
  margin: 1rem;
  padding: 2.5rem 1.25rem 1.25rem;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.35);
  display: flex;
  flex-direction: column;
}

.mermaid-zoom-close {
  position: absolute;
  top: 0.5rem;
  right: 0.75rem;
  width: 2rem;
  height: 2rem;
  border: none;
  border-radius: 6px;
  background: transparent;
  color: #666;
  font-size: 1.75rem;
  line-height: 1;
  cursor: pointer;
}

.mermaid-zoom-close:hover {
  background: rgba(0, 0, 0, 0.06);
  color: #333;
}

.mermaid-zoom-hint {
  margin: 0 0 0.75rem;
  font-size: 0.8rem;
  color: #888;
  text-align: center;
  flex-shrink: 0;
}

.mermaid-zoom-content {
  flex: 1;
  min-height: 0;
  overflow: auto;
  text-align: center;
}

.mermaid-zoom-content svg {
  max-width: none !important;
  width: auto !important;
  height: auto !important;
  min-width: unquote('min(100%, 800px)')
}

/* 文章标题下 AI 总结入口（reco: .page-title 内） */
.page-title .ai-summarize-bar {
  width: 100%;
  padding-left: 0;
  padding-right: 0;
}

.ai-summarize-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  margin: 0.75rem 0 1.25rem;
  padding: 0;
}

.ai-summarize-bar__label {
  font-size: 15px;
  font-weight: 600;
  color: #565656;
  line-height: 1.4;
  margin-right: 0.15rem;
}

.ai-summarize-bar__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.35rem 0.75rem;
  font-size: 14px;
  font-weight: 500;
  color: #333 !important;
  text-decoration: none !important;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(0, 0, 0, 0.08);
  transition: background-color 0.15s ease;
}

.ai-summarize-bar__btn:hover {
  background: #e8ecef !important;
  color: #333 !important;
}

.ai-summarize-bar__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-summarize-bar__icon svg,
.ai-summarize-bar__icon img {
  display: block;
  width: 16px;
  height: 16px;
  object-fit: contain;
}

.ai-summarize-bar__icon img {
  border-radius: 4px;
}

.theme-mode-dark .ai-summarize-bar__label {
  color: #b8b8b8;
}

.theme-mode-dark .ai-summarize-bar__btn {
  color: #e8e8e8 !important;
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.12);
}

.theme-mode-dark .ai-summarize-bar__btn:hover {
  background: rgba(255, 255, 255, 0.16) !important;
}

.ai-summarize-bar--stack {
  flex-direction: column;
  align-items: stretch;
  gap: 0.35rem;
  margin: 0;
}

.ai-summarize-bar--stack .ai-summarize-bar__btn {
  width: 100%;
  justify-content: flex-start;
}

/* 右侧悬浮面板 */
.ai-summarize-float-root {
  position: fixed;
  z-index: 520;
  pointer-events: none;
}

.ai-summarize-float-root > * {
  pointer-events: auto;
}

.ai-summarize-float {
  position: fixed;
  z-index: 521;
  max-width: unquote('min(280px, calc(100vw - 24px))')
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(0, 0, 0, 0.1);
  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(8px);
  font-size: 13px;
  user-select: none;
}

.ai-summarize-float.is-dragging {
  box-shadow: 0 12px 36px rgba(0, 0, 0, 0.18);
  cursor: grabbing;
}

.ai-summarize-float__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  padding: 0.45rem 0.55rem 0.45rem 0.65rem;
  cursor: grab;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 12px 12px 0 0;
}

.ai-summarize-float.is-collapsed .ai-summarize-float__head {
  border-bottom: none;
  border-radius: 12px;
}

.ai-summarize-float__title {
  font-weight: 600;
  color: #565656;
  white-space: nowrap;
}

.ai-summarize-float__actions {
  display: flex;
  gap: 0.25rem;
  flex-shrink: 0;
}

.ai-summarize-float__btn {
  border: none;
  background: rgba(0, 0, 0, 0.05);
  color: #444;
  font-size: 12px;
  padding: 0.2rem 0.45rem;
  border-radius: 6px;
  cursor: pointer;
  line-height: 1.3;
}

.ai-summarize-float__btn:hover {
  background: #e8ecef;
}

.ai-summarize-float__body {
  padding: 0.5rem 0.55rem 0.6rem;
  max-height: unquote('min(70vh, 420px)')
  overflow-y: auto;
}

.ai-summarize-float-restore {
  position: fixed;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 521;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid rgba(0, 0, 0, 0.1);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  font-size: 13px;
  font-weight: 700;
  color: #4d6bfe;
  cursor: pointer;
  padding: 0;
}

.ai-summarize-float-restore:hover {
  background: #e8ecef;
}

body.ai-summarize-float-dragging {
  cursor: grabbing !important;
}

body.ai-summarize-float-dragging * {
  cursor: grabbing !important;
}

.theme-mode-dark .ai-summarize-float {
  background: rgba(30, 35, 45, 0.96);
  border-color: rgba(255, 255, 255, 0.12);
}

.theme-mode-dark .ai-summarize-float__title {
  color: #d0d0d0;
}

.theme-mode-dark .ai-summarize-float__btn {
  background: rgba(255, 255, 255, 0.08);
  color: #ddd;
}

.theme-mode-dark .ai-summarize-float-restore {
  background: rgba(30, 35, 45, 0.95);
  color: #7b9cff;
}

@media (max-width: 768px) {
  .ai-summarize-float {
    max-width: calc(100vw - 16px);
  }
}
